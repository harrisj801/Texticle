{
	"name": "XML (Minimal)",
	"scopeName": "text.xml",
	"patterns": [
		{
			"include": "#prolog"
		},
		{
			"include": "#comment"
		},
		{
			"include": "#doctype"
		},
		{
			"include": "#tag"
		}
	],
	"repository": {
		"prolog": {
			"name": "meta.prolog.xml",
			"begin": "<\\?(xml)",
			"beginCaptures": {
				"1": {
					"name": "entity.name.tag.xml"
				}
			},
			"end": "\\?>",
			"patterns": [
				{
					"include": "#attr"
				}
			]
		},
		"comment": {
			"name": "comment.block.xml",
			"begin": "<!--",
			"end": "-->"
		},
		"doctype": {
			"name": "meta.doctype.xml",
			"begin": "<!DOCTYPE",
			"end": ">",
			"patterns": [
				{
					"match": "\"[^\"]*\"",
					"name": "string.quoted.double.xml"
				},
				{
					"match": "'[^']*'",
					"name": "string.quoted.single.xml"
				}
			]
		},
		"tag": {
			"begin": "<(/)?([A-Za-z_][\\w:.-]*)",
			"beginCaptures": {
				"1": {
					"name": "punctuation.definition.tag.begin.xml"
				},
				"2": {
					"name": "entity.name.tag.xml"
				}
			},
			"end": "(/?)>",
			"endCaptures": {
				"1": {
					"name": "punctuation.definition.tag.end.xml"
				}
			},
			"name": "meta.tag.xml",
			"patterns": [
				{
					"include": "#attr"
				},
				{
					"include": "#comment"
				}
			]
		},
		"attr": {
			"patterns": [
				{
					"name": "entity.other.attribute-name.xml",
					"match": "\\b([A-Za-z_][\\w:.-]*)\\b(?=\\s*=)"
				},
				{
					"begin": "=",
					"end": "(?=[>\\s])",
					"patterns": [
						{
							"name": "string.quoted.double.xml",
							"begin": "\"",
							"end": "\"",
							"patterns": [
								{
									"name": "constant.character.entity.xml",
									"match": "&[A-Za-z0-9#]+;"
								}
							]
						},
						{
							"name": "string.quoted.single.xml",
							"begin": "'",
							"end": "'",
							"patterns": [
								{
									"name": "constant.character.entity.xml",
									"match": "&[A-Za-z0-9#]+;"
								}
							]
						}
					]
				}
			]
		}
	}
}